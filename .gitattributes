# Normalize all text files to LF on commit, regardless of platform.
* text=auto eol=lf

# Binary assets
*.glb binary
*.gltf binary
*.hdr binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary

# Lock files
package-lock.json text eol=lf
